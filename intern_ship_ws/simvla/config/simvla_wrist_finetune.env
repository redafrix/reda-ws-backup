# One-time local config for wrist-only SimVLA fine-tuning.
# After editing LIBERO_DATA_DIR, the common command is just:
#   ./run_simvla_wrist_finetune.sh
#
# To resume later:
#   ./run_simvla_wrist_finetune.sh resume /path/to/ckpt-XXXX

# Required: real LIBERO HDF5 dataset root containing libero_10, libero_goal, etc.
: "${LIBERO_DATA_DIR:=$WS_ROOT/assets/data/libero_datasets}"

# Optional overrides
: "${BATCH_SIZE:=1}"
: "${LEARNING_COEF:=0.1}"
: "${OUTPUT_DIR:=$WS_ROOT/outputs/runs/simvla_libero_wrist_only}"
: "${PRETRAINED_CKPT:=$WS_ROOT/assets/models/huggingface/SimVLA-LIBERO}"

# Training hyperparameters
: "${LEARNING_RATE:=1e-4}"
: "${NUM_ACTIONS:=10}"
: "${ITERS:=200000}"
: "${WARMUP_STEPS:=0}"
: "${FREEZE_STEPS:=200000}"
: "${SAVE_INTERVAL:=10000}"
: "${LOG_INTERVAL:=20}"
: "${NUM_WORKERS:=2}"
: "${MAX_GRAD_NORM:=1.0}"

# Model config
: "${HIDDEN_SIZE:=768}"
: "${DEPTH:=12}"
: "${NUM_HEADS:=12}"
: "${USE_ADALN:=false}"

# Runtime
: "${CUDA_VISIBLE_DEVICES:=0}"
: "${MAIN_PROCESS_PORT:=29514}"
# Released SimVLA-code setup:
# - LIBERO-Spatial
# - LIBERO-Object
# - LIBERO-Goal
# - LIBERO-10
# - LIBERO-90
: "${SUBSETS:=libero_10 libero_goal libero_object libero_spatial libero_90}"
